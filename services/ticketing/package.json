{
  "name": "ticketing",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "GPL-3.0",
  "scripts": {
    "build": "nest build",
    "build:libs": "npm --prefix ../../libs/ts-common run build && npm --prefix ../../libs/nestjs-common run build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "sh ./scripts/clean-db.sh && nest start",
    "start:dev": "sh ./scripts/clean-db.sh && nest start --watch",
    "start-dev": "NODE_ENV=development npm run build:libs && npm run start",
    "start-dev:dev": "NODE_ENV=development npm run build:libs && npm run start:dev",
    "start-with-dev-env": "NODE_ENV=development ENV=development npm run start",
    "start-with-dev-env:dev": "NODE_ENV=development ENV=development npm run start:dev",
    "start-debug": "nest start --debug",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "pretest": "npm run build:libs",
    "test": "npm run pretest && jest",
    "test:cov": "npm run pretest && jest --coverage",
    "test:unit": "npm run pretest && jest --config ./test/unit/jest-unit.json",
    "test:unit:watch": "npm run pretest && jest --config ./test/unit/jest-unit.json --watch",
    "test:unit:cov": "npm run pretest && jest --config ./test/unit/jest-unit.json --coverage",
    "test:integration": "npm run pretest && jest --config ./test/integration/jest-integration.json",
    "test:integration:watch": "npm run pretest && jest --config ./test/integration/jest-integration.json --watch",
    "test:integration:cov": "npm run pretest && jest --config ./test/integration/jest-integration.json --coverage",
    "test:e2e": "npm run pretest && jest --config ./test/e2e/jest-e2e.json",
    "test:e2e:watch": "npm run pretest && jest --config ./test/e2e/jest-e2e.json --watch",
    "test:e2e:cov": "npm run pretest && jest --config ./test/e2e/jest-e2e.json --coverage"
  },
  "dependencies": {
    "@libs/nestjs-common": "file:../../libs/nestjs-common",
    "@libs/ts-common": "file:../../libs/ts-common",
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/microservices": "^11.1.11",
    "@nestjs/mongoose": "^11.0.3",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@types/amqplib": "^0.10.8",
    "@types/stripe": "^8.0.416",
    "amqp-connection-manager": "^5.0.0",
    "amqplib": "^0.10.9",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "currency-codes": "^2.2.0",
    "dotenv": "^17.2.3",
    "easy-currencies": "^1.8.3",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.20.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdfkit": "^0.17.2",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "stripe": "20.1.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.7",
    "@types/passport-jwt": "^4.0.1",
    "@types/pdfkit": "^0.17.4",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "mongodb-memory-server": "^11.0.1",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  }
}
